# Supabase project URL, for example:
# https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase public anon key.
# This is the "key" Supabase commonly shows next to the project URL.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role key.
# Required for this MVP because sensitive operations run server-side:
# assigning/moving The Million, resolving Bazookas, admin reads, private clues.
# Find it in Supabase project settings under API / Project API keys.
# Keep this secret. Never expose it in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Used to sign the simple admin session cookie.
# If omitted, the app uses a development fallback.
ADMIN_SESSION_SECRET=
